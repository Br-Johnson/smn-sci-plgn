{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ColumbiaBasinIdentitySliceV0",
  "type": "object",
  "required": [
    "slice_id",
    "version",
    "scope",
    "scheme_definitions",
    "records"
  ],
  "properties": {
    "slice_id": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "generated_on": {
      "type": "string"
    },
    "scope": {
      "type": "object",
      "required": [
        "region",
        "status",
        "authority",
        "assumption"
      ],
      "properties": {
        "region": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "authority": {
          "type": "string"
        },
        "assumption": {
          "type": "string"
        }
      }
    },
    "scheme_definitions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/schemeDefinition"
      }
    },
    "records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/record"
      }
    }
  },
  "$defs": {
    "schemeDefinition": {
      "type": "object",
      "required": [
        "scheme",
        "definition"
      ],
      "properties": {
        "scheme": {
          "type": "string"
        },
        "definition": {
          "type": "string"
        },
        "example": {
          "type": "string"
        }
      }
    },
    "provenanceEntry": {
      "type": "object",
      "required": [
        "source",
        "basis"
      ],
      "properties": {
        "source": {
          "type": "string"
        },
        "basis": {
          "type": "string"
        }
      }
    },
    "record": {
      "type": "object",
      "required": [
        "canonical_local_id",
        "entity_type",
        "label",
        "aliases",
        "identifier_scheme",
        "identifier_value",
        "mapped_target_id",
        "mapping_relation",
        "provenance",
        "confidence",
        "record_status",
        "valid_from",
        "valid_time_or_version",
        "notes"
      ],
      "properties": {
        "canonical_local_id": {
          "type": "string"
        },
        "entity_type": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "aliases": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "identifier_scheme": {
          "type": "string"
        },
        "identifier_value": {
          "type": "string"
        },
        "mapped_target_id": {
          "type": "string"
        },
        "mapping_relation": {
          "type": "string"
        },
        "source": {
          "type": "string"
        },
        "confidence": {
          "type": "string"
        },
        "record_status": {
          "type": "string"
        },
        "valid_from": {
          "type": "string"
        },
        "valid_to": {
          "type": [
            "string",
            "null"
          ]
        },
        "valid_time_or_version": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        },
        "slice_id": {
          "type": "string"
        },
        "scheme_definition": {
          "type": "object"
        },
        "provenance": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/provenanceEntry"
          }
        }
      }
    }
  }
}
